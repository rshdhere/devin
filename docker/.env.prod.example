# Copy to docker/.env.prod and fill in before running compose-prod.yaml

DOCKERHUB_USERNAME=rshdhere
IMAGE_TAG=latest

POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me
POSTGRES_DB=devin

SERVER_PORT=8080
WEB_PORT=3000

DATABASE_URL=postgres://postgres:change-me@postgres:5432/devin

# Public URLs — must match your domain (also stored in Vault secret/prod/ci)
BETTER_AUTH_URL=https://api.devin.baby
WEB_APP_URL=https://devin.baby
PORT=8080

# Baked into the web image at build time — rebuild web after changing these
NEXT_PUBLIC_API_URL=https://api.devin.baby
NEXT_PUBLIC_WEB_APP_URL=https://devin.baby

BETTER_AUTH_SECRET=
RESEND_API_KEY=
RESEND_FROM_EMAIL="Devin <onboarding@resend.dev>"
RESEND_STRICT=true

# Optional OAuth
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
