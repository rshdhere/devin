FIRECRACKER_HOST_PORT=9092
FIRECRACKER_HOST_NAME=fc-local
FIRECRACKER_DRY_RUN=true
RUNTIME_URL=http://localhost:8081

# Production Firecracker (FIRECRACKER_DRY_RUN=false)
FIRECRACKER_BIN=/usr/bin/firecracker
FIRECRACKER_KERNEL_PATH=/var/lib/devin/linux/vmlinux
FIRECRACKER_SNAPSHOT_DIR=/var/lib/devin/snapshots
FIRECRACKER_VMM_DIR=/var/lib/devin/vms
FIRECRACKER_POOL_SIZE=1
FIRECRACKER_DEFAULT_RUNTIME=nextjs
FIRECRACKER_RUNTIME_PORT=8081
FIRECRACKER_CNI_NETWORK=fcnet
FIRECRACKER_CNI_CONF_DIR=/etc/cni/conf.d
FIRECRACKER_CNI_BIN_PATH=/opt/cni/bin
FIRECRACKER_CAPACITY_CPU=32
FIRECRACKER_CAPACITY_MEMORY=64Gi
FIRECRACKER_WARM_VCPU=2
FIRECRACKER_WARM_MEMORY_MIB=8192
