SCHEDULER_PORT=9091
ORCHESTRATOR_URL=http://localhost:9090
RUNTIME_URL=http://localhost:8081
FIRECRACKER_HOST_URL=http://localhost:9092
# Firecracker cold starts and orchestrator reconciliation can exceed 15s.
SANDBOX_READY_TIMEOUT_SECONDS=300
RUNTIME_READY_TIMEOUT_SECONDS=60
# Pin sandboxes to the FirecrackerHost CR on this machine (must match metadata.name).
# SCHEDULER_HOST_NAME=devin-production-fc-01
# FIRECRACKER_HOST_NAME=devin-production-fc-01  # fallback when SCHEDULER_HOST_NAME unset

# Service mode: standalone (default) | worker (execution host behind brain)
# SERVICE_MODE=standalone
# SERVICE_MODE=worker

# Brain control plane delegates sandbox work to the execution worker:
# EXECUTION_WORKER_URL=http://execution-host:9091

# Agent credentials live on the execution host only (never in the web UI).
# DEFAULT_AGENT=cursor
# CURSOR_API_KEY=
# ANTHROPIC_API_KEY=

# Legacy template agent only (control-plane OpenAI draft — not used by web UI):
# OPENAI_API_KEY=
# DRAFT_PLANNER_OPENAI_MODEL=gpt-4o-mini

# GitHub bot account for new repos, issues, and bot-owned pushes (baby-devin-bot)
# REQUIRED for "Create repositories" feature. Without this, repo creation fails with 401.
# Create a GitHub Personal Access Token (classic) with 'repo' scope for the bot account.
# The token must belong to the same GitHub account as GITHUB_BOT_NAME.
# GITHUB_BOT_TOKEN=ghp_xxx
# GITHUB_BOT_NAME=baby-devin-bot
# GITHUB_BOT_EMAIL=baby-devin-bot@users.noreply.github.com

# Queue driver: memory (local) | sqs (AWS production)
QUEUE_DRIVER=memory
# QUEUE_DRIVER=sqs
# SQS_QUEUE_URL=https://sqs.ap-south-1.amazonaws.com/123456789012/devin-production-tasks
# AWS_REGION=ap-south-1
# SQS_VISIBILITY_TIMEOUT_SECONDS=300

# Service mode: standalone (default) | worker (execution host behind brain)
# SERVICE_MODE=standalone
# SERVICE_MODE=worker

# Durable tasks/sessions in Postgres (recommended for production)
# DATABASE_URL=postgresql://user:pass@host:5432/devin

# Idle devbox sleep after N seconds without activity (default 1800 = 30m)
# DEVBOX_IDLE_TIMEOUT_SECONDS=1800
