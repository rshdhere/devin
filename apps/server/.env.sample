BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:8080
WEB_APP_URL=http://localhost:3000
# Comma-separated extra browser origins allowed for CORS and OAuth (e.g. staging web)
# CORS_ALLOWED_ORIGINS=https://staging.devin.baby
PORT=8080
DATABASE_URL="postgres://postgres:postgres@localhost:5432/devin"

# Scheduler (task orchestration for devin.baby)
SCHEDULER_URL=http://localhost:9091

# Email (Resend)
RESEND_API_KEY=
RESEND_FROM_EMAIL="Devin <onboarding@resend.dev>"
# Set to true in production to fail auth flows when email delivery fails
RESEND_STRICT=false

# Optional OAuth providers
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
WINDSURF_CLIENT_ID=
WINDSURF_CLIENT_SECRET=
WINDSURF_DISCOVERY_URL=
