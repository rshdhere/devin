# Generated by Terraform — sync to your GitOps repo (production/devin/overlays/external/firecracker-hosts.yaml).
%{ for key, host in hosts ~}
---
apiVersion: devin.baby/v1
kind: FirecrackerHost
metadata:
  name: ${host.name}
  namespace: devin-firecracker
spec:
  address: ${host.address}
  schedulerAddress: ${host.scheduler}
  capacity:
    cpu: 8
    memory: 16Gi
%{ endfor ~}
